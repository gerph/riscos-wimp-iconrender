#include <assert.h>
#include <stdlib.h>
#include <stdio.h>

#include "swis.h"

#include "GContext/gcontext.h"
#include "types.h"

#include "VersionNum"

//#define FONT_NAME "Corpus.Medium"
#define FONT_NAME "Trinity.Medium.Italic"
#define FONT_XSIZE (12*16)
#define FONT_YSIZE (12*16)

void draw_text_diagram(gcontext_t *gcontext,
                       int x, int y,
                       const char *text, int textlen)
{
    stringbounds_t bounds;
    int width;
    int xoffset;

    font_t font = gcontext->text_findfont(gcontext, FONT_NAME, FONT_XSIZE, FONT_YSIZE);

    gcontext->text_getstringsize(gcontext, font,
                                 &bounds, 0x7FFFFFFF,
                                 text, textlen, GCONTEXT_NOSPLIT);

    width = bounds.xoffset + bounds.rbearing;
    xoffset  = bounds.xoffset;

    gcontext->text_paint(gcontext, font,
                         x, y, COLOUR_RGB(0,0,0), COLOUR_RGB(255,255,255),
                         text, textlen);

    gcontext->line_start(gcontext, COLOUR_RGB(96, 96, 255));
    gcontext->line_line(gcontext, x, y, x + xoffset, y);
    gcontext->line_line(gcontext, x, y - 8, x + width, y - 8);
    gcontext->line_end(gcontext);

    gcontext->text_losefont(gcontext, font);
}

void testgcontext(void)
{
    gcontext_t *gcontext = gcontext_initvdu(2);

    gcontext->rectangle_fill(gcontext, 0x81397900, 64, 64, 500,500);

    draw_text_diagram(gcontext, 64, 800, "The quick brown fox jumped over the lazy dog!", 5);
    draw_text_diagram(gcontext, 64, 720, "The quick brown fox jumped over the lazy dog!", GCONTEXT_ZEROTERM);

    exit(EXIT_SUCCESS);
}
