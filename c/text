#include "text.h"
#include <string.h>

#define FONT_NAME "Trinity.Medium"
#define FONT_XSIZE (12*16)
#define FONT_YSIZE (12*16)

/*************************************************** Gerph *********
 Function:      text_size
 Description:   Get the size of some text
 Parameters:    text = string
                width -> where to store width
                height -> where to store height
 Returns:       void
 ******************************************************************/
void text_size(const char *text, int *width, int *height)
{
    if (text == NULL)
    {
        *width = 0;
        *height = 0;
    }
    else
    {
        *width = strlen(text) * 16; // Simple estimation for system font
        *height = 32;
    }
}

/*************************************************** Gerph *********
 Function:      text_render
 Description:   Render some text using GContext
 Parameters:    gcontext -> graphics context
                fg, bg = colours
                text = string
                x, y = position
                clip_x0, clip_y0, clip_x1, clip_y1 = clipping box
 Returns:       void
 ******************************************************************/
void text_render(gcontext_t *gcontext, colour_t fg, colour_t bg, const char *text,
                 int x, int y, int clip_x0, int clip_y0, int clip_x1, int clip_y1)
{
    if (text == NULL) return;

    {
        font_t font = gcontext->text_findfont(gcontext, FONT_NAME, FONT_XSIZE, FONT_YSIZE);
        if (font != FONT_NONE)
        {
            // Note: gcontext handles clipping if state is set, 
            // but we'll just paint it at the requested position.
            // Wimp text is usually drawn from the baseline.
            gcontext->text_paint(gcontext, font, x, y + 8, bg, fg, text, GCONTEXT_ZEROTERM);
            gcontext->text_losefont(gcontext, font);
        }
    }
}
